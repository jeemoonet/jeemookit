# 复制到 ~/.jeemoo/secrets.env 并填写（勿提交进任何 Git 仓库）
# cp templates/secrets.env.example ~/.jeemoo/secrets.env

# KIMI
# KIMI_API_KEY=

# GitHub PAT（服务器 git pull）
# GITHUB_PAT=

# 飞书（md-to-feishu Skill，默认用户 OAuth，无需机器人）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_FOLDER_TOKEN=          # 可选，导入到你自己的云空间文件夹
# FEISHU_REDIRECT_URI=http://127.0.0.1:8765/callback  # 可选，须在应用后台配置
# FEISHU_DOMAIN=open.feishu.cn  # 可选，国际版用 open.larksuite.com
